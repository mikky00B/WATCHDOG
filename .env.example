# Database Configuration
DATABASE_URL=postgresql+asyncpg://monitoring_user:monitoring_pass@localhost:5432/monitoring_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Monitoring Configuration
DEFAULT_CHECK_INTERVAL=60
DEFAULT_TIMEOUT=5.0
MAX_CONCURRENT_CHECKS=100

# SMTP Configuration (for email alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=alerts@monitoring.com
ALERT_EMAILS=alerts@example.com,ops@example.com

# Slack Configuration (for Slack alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram Configuration (for Telegram alerts + bot control)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/integrations/telegram/webhook
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# Logging
LOG_LEVEL=INFO
